{
  "name": "xpath-css-selector-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:chrome",
    "build:chrome": "node scripts/sync-manifest.mjs chrome && node esbuild.config.mjs",
    "build:firefox": "node scripts/sync-manifest.mjs firefox && node esbuild.config.mjs",
    "watch": "npm run watch:chrome",
    "watch:chrome": "node scripts/sync-manifest.mjs chrome && node esbuild.config.mjs --watch",
    "watch:firefox": "node scripts/sync-manifest.mjs firefox && node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "release:check": "npm run typecheck && npm run build"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3"
  }
}
